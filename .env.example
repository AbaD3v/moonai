# MoonAI Backend — Environment Config Template
# Скопируй в .env и заполни свои значения

# Режим работы: mock | api | local
MOON_MODE=api

# ── Облачная модель (MODE=api) ──────────────────────────────
# URL твоего inference эндпоинта (OpenAI-compatible)
# Примеры:
#   RunPod:   https://api.runpod.ai/v2/{pod_id}/openai/v1/chat/completions
#   Together: https://api.together.xyz/v1/chat/completions
#   vLLM:     http://your-server:8080/v1/chat/completions
MODEL_API_URL=
VITE_MOONAI_API_URL=

# API ключ (если нужен)
MODEL_API_KEY=

# Название модели (передаётся в payload)
MODEL_NAME=moonai