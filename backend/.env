# MoonAI Backend Configuration
# ==================================

# Режим работы: "mock" | "api" | "local"
# - mock  : заглушка для тестирования
# - api   : облачная модель через HTTP API
# - local : локальная MoonAI модель (PyTorch)
MOON_MODE=local

# Если используешь MODE=api, раскомментируй и заполни:
# MODEL_API_URL=https://your-api-endpoint.com/v1/chat/completions
# MODEL_API_KEY=your-api-key-here
# MODEL_NAME=moonai-v2

# CUDA/GPU настройки (опционально)
# CUDA_VISIBLE_DEVICES=0
